	<error-handler name="SubFlow_Error_Handler">
		<on-error-propagate enableNotifications="true"
			logException="true" doc:name="On Error Propagate"
			doc:id="bc801468-066e-4231-a792-222b0c7413aa">
			<ee:transform doc:name="Transform Message"
				doc:id="30c4eb3f-6c20-4bf2-8800-77597f5e7f41">
				<ee:message>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="mapError"><![CDATA[%dw 2.0
output application/json
var mainError = error.suppressedErrors[0] default error
var attrs = mainError.errorMessage.attributes default {}
var headers = attrs.headers default {}
var contentLength = headers."content-length" default "-1"
---
{
    "code": attrs.statusCode default 500,
    "correlation_id": correlationId,
    "reason": mainError.errorType.identifier 
            default "Unknown Error",
    "detail": error.description 
            default mainError.cause.localizedMessage 
            default "No details available",
    "response": if (contentLength == "0") null else mainError.errorMessage.payload
}
]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<set-variable value="500" doc:name="httpStatus"
				doc:id="755887c7-3da4-47d9-ae4a-dc2be0af7a89"
				variableName="httpStatus" />
			<set-payload
				value='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;    "code": 500,&#10;    "correlation_id": correlationId,&#10;    "reason": "INTERNAL_SERVER_ERROR",&#10;    "detail": "Erro no processamento da requisição - código: " ++ correlationId,    &#10;}]'
				doc:name="Set Payload" doc:id="054c431b-e857-4eac-abf8-7511b44e1ebb" />
			<logger level="ERROR" doc:name="Logger"
				doc:id="930ec663-f87e-4f83-9de6-e7a1ae9c8c9a"
				message="#[output application/java&#10;---&#10;'&#10;Trace Point - ERROR - ' &#10;++ write(vars.attributes.requestPath,'application/json') ++ '&#10;'&#10;++&#10;write(vars.mapError,'application/json')]" />
		</on-error-propagate>
	</error-handler>
